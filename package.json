{
  "name": "codex-usage-monitor",
  "version": "0.2.0",
  "description": "Read-only Codex quota and token usage monitor plugin with ZCode token tracking",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "out/main/index.js",
  "files": [
    ".codex-plugin",
    ".mcp.json",
    "docs",
    "dist",
    "out",
    "electron",
    "renderer",
    "shared",
    "companion",
    "scripts",
    "LICENSE",
    "start-floating-window.cmd",
    "start-floating-window.vbs",
    "skills",
    "README.md"
  ],
  "build": {
    "appId": "com.hieronymusf.usage-monitor",
    "productName": "Usage Monitor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "dist/**/*",
      "package.json",
      "!dist/**/.gitkeep"
    ],
    "extraResources": [
      {
        "from": "electron/probe-daemon.ps1",
        "to": "probe-daemon.ps1"
      },
      {
        "from": "resources/usage-monitor.ico",
        "to": "usage-monitor.ico"
      }
    ],
    "win": {
      "icon": "resources/usage-monitor.ico",
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "usage-monitor-portable-${version}.exe"
    }
  },
  "scripts": {
    "build": "npm run build:server && npm run build:desktop",
    "build:server": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "build:desktop": "electron-vite build",
    "predev": "npm run build:server",
    "dev": "electron-vite dev",
    "prestart": "npm run build",
    "start": "electron-vite preview",
    "typecheck": "npm run typecheck:server && npm run typecheck:desktop && npm run typecheck:tests",
    "typecheck:server": "node ./node_modules/typescript/bin/tsc --noEmit",
    "typecheck:desktop": "node ./node_modules/typescript/bin/tsc -p tsconfig.electron.json --noEmit && node ./node_modules/typescript/bin/tsc -p renderer/tsconfig.json --noEmit",
    "typecheck:tests": "node ./node_modules/typescript/bin/tsc -p tests/renderer/tsconfig.json --noEmit && node ./node_modules/typescript/bin/tsc -p tests/electron/tsconfig.json --noEmit",
    "lint": "node scripts/lint.mjs && eslint electron renderer/src shared tests/renderer tests/electron electron.vite.config.ts",
    "format:check": "prettier --check electron renderer shared tests/renderer tests/electron electron.vite.config.ts components.json",
    "test": "npm run build:server && node --import tsx --test tests/renderer/*.test.ts && node --import tsx --test tests/renderer/*.test.tsx && node --import tsx --test tests/renderer/components/*.test.tsx && node --import tsx --test tests/electron/*.test.ts",
    "test:server": "node --test tests/*.test.js",
    "companion": "npm run build:server && powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./companion/CodexUsageMonitor.ps1",
    "install:companion": "powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-floating-window.ps1",
    "install:startup": "powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/manage-startup.ps1 -Action Enable",
    "uninstall:startup": "powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/manage-startup.ps1 -Action Disable",
    "status:startup": "powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/manage-startup.ps1 -Action Status",
    "validate:plugin": "node scripts/validate-plugin.mjs",
    "capture": "node scripts/capture.mjs",
    "capture:all": "node scripts/capture-all.mjs",
    "capture:diff": "node scripts/diff.mjs",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test && npm run build && npm run validate:plugin && npm run test:server",
    "dist": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.333",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.6",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6"
  }
}
